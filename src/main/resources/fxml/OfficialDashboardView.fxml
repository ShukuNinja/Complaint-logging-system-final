<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.OfficialDashboardController">
   <top>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FF9933;">
         <children>
            <Label text="Official Dashboard - Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter Bold" size="28.0" />
               </font>
            </Label>
            <Label text="अधिकारी डैशबोर्ड - शिकायत प्रबंधन प्रणाली" textFill="WHITE">
               <font>
                  <Font name="Inter" size="16.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <BorderPane style="-fx-background-color: #FFFFFF;">
         <top>
            <VBox spacing="15.0" style="-fx-background-color: #f8f9fa; -fx-border-color: #000080; -fx-border-width: 0 0 2 0;">
               <children>
                  <Label fx:id="welcomeLabel" text="Welcome" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="20.0" />
                     </font>
                  </Label>
                  <HBox spacing="15.0" alignment="CENTER_LEFT">
                     <children>
                        <Label text="Filter By:" textFill="#000080">
                           <font>
                              <Font name="Inter Bold" size="14.0" />
                           </font>
                        </Label>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Department:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="12.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="departmentFilterComboBox" promptText="All Departments" prefWidth="200.0" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                              </ComboBox>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Status:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="12.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="statusFilterComboBox" promptText="All Statuses" prefWidth="150.0" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                              </ComboBox>
                           </children>
                        </VBox>
                        <Button fx:id="applyFilterButton" onAction="#handleApplyFilter" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;">
                           <font>
                              <Font name="Inter Bold" size="12.0" />
                           </font>
                           <text>Apply Filter</text>
                        </Button>
                        <Button fx:id="clearFilterButton" onAction="#handleClearFilter" style="-fx-background-color: #6c757d; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;">
                           <font>
                              <Font name="Inter Bold" size="12.0" />
                           </font>
                           <text>Clear</text>
                        </Button>
                        <Button fx:id="refreshButton" onAction="#handleRefresh" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8 15; -fx-cursor: hand;">
                           <font>
                              <Font name="Inter Bold" size="12.0" />
                           </font>
                           <text>Refresh</text>
                        </Button>
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
               </padding>
            </VBox>
         </top>
         <center>
            <SplitPane dividerPositions="0.6">
               <items>
                  <VBox spacing="10.0">
                     <children>
                        <Label text="All Complaints" textFill="#000080">
                           <font>
                              <Font name="Inter Bold" size="18.0" />
                           </font>
                        </Label>
                        <TableView fx:id="complaintsTable" prefHeight="500.0">
                           <columns>
                              <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0" />
                              <TableColumn fx:id="titleColumn" text="Title" prefWidth="200.0" />
                              <TableColumn fx:id="lodgedByColumn" text="Lodged By" prefWidth="120.0" />
                              <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120.0" />
                              <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0" />
                              <TableColumn fx:id="lodgedAtColumn" text="Lodged At" prefWidth="130.0" />
                           </columns>
                        </TableView>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="10.0" top="20.0" />
                     </padding>
                  </VBox>
                  <VBox fx:id="complaintDetailsPanel" spacing="15.0" style="-fx-border-color: #000080; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-color: #FFFFFF;">
                     <children>
                        <Label text="Complaint Details" textFill="#000080">
                           <font>
                              <Font name="Inter Bold" size="18.0" />
                           </font>
                        </Label>
                        <Separator />
                        <VBox spacing="10.0">
                           <children>
                              <Label text="Title:" textFill="#000080">
                                 <font>
                                    <Font name="Inter Bold" size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="detailTitleLabel" text="" wrapText="true" textFill="#333333">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <VBox spacing="10.0">
                           <children>
                              <Label text="Description:" textFill="#000080">
                                 <font>
                                    <Font name="Inter Bold" size="14.0" />
                                 </font>
                              </Label>
                              <Label fx:id="detailDescriptionLabel" text="" wrapText="true" textFill="#333333">
                                 <font>
                                    <Font name="Inter" size="13.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <HBox spacing="30.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Lodged By:" textFill="#000080">
                                       <font>
                                          <Font name="Inter Bold" size="12.0" />
                                       </font>
                                    </Label>
                                    <Label fx:id="detailLodgedByLabel" text="" textFill="#333333">
                                       <font>
                                          <Font name="Inter" size="12.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Department:" textFill="#000080">
                                       <font>
                                          <Font name="Inter Bold" size="12.0" />
                                       </font>
                                    </Label>
                                    <Label fx:id="detailDepartmentLabel" text="" textFill="#333333">
                                       <font>
                                          <Font name="Inter" size="12.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <HBox spacing="30.0">
                           <children>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Status:" textFill="#000080">
                                       <font>
                                          <Font name="Inter Bold" size="12.0" />
                                       </font>
                                    </Label>
                                    <Label fx:id="detailStatusLabel" text="" textFill="#333333">
                                       <font>
                                          <Font name="Inter" size="12.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                              <VBox spacing="5.0">
                                 <children>
                                    <Label text="Lodged At:" textFill="#000080">
                                       <font>
                                          <Font name="Inter Bold" size="12.0" />
                                       </font>
                                    </Label>
                                    <Label fx:id="detailLodgedAtLabel" text="" textFill="#333333">
                                       <font>
                                          <Font name="Inter" size="12.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        <Separator />
                        <Label text="Update Status" textFill="#000080">
                           <font>
                              <Font name="Inter Bold" size="16.0" />
                           </font>
                        </Label>
                        <VBox spacing="10.0">
                           <children>
                              <Label text="New Status:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="statusUpdateComboBox" maxWidth="Infinity" promptText="Select new status" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                              </ComboBox>
                           </children>
                        </VBox>
                        <VBox spacing="10.0">
                           <children>
                              <Label text="Remarks:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <TextArea fx:id="remarksArea" promptText="Enter remarks (optional)" prefHeight="80.0" wrapText="true" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="13.0" />
                                 </font>
                              </TextArea>
                           </children>
                        </VBox>
                        <Button fx:id="updateStatusButton" maxWidth="Infinity" onAction="#handleUpdateStatus" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10; -fx-cursor: hand;">
                           <font>
                              <Font name="Inter Bold" size="14.0" />
                           </font>
                           <text>Update Status</text>
                        </Button>
                        <Label fx:id="updateStatusLabel" textFill="#dc3545" visible="false" wrapText="true">
                           <font>
                              <Font name="Inter" size="12.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </items>
            </SplitPane>
         </center>
      </BorderPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #000080;">
         <children>
            <Button fx:id="logoutButton" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: WHITE; -fx-border-width: 0; -fx-cursor: hand;">
               <font>
                  <Font name="Inter Bold" size="12.0" />
               </font>
               <text>Logout</text>
            </Button>
            <Label text="© 2025 Government of India - Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter" size="12.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>