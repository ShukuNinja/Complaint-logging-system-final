<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.OfficialDashboardController">
   <top>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FF9933;">
         <children>
            <Label text="Citizen Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter Bold" size="28.0" />
               </font>
            </Label>
            <Label text="सरकारी शिकायत प्रबंधन प्रणाली" textFill="WHITE">
               <font>
                  <Font name="Inter" size="16.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.6" style="-fx-background-color: #FFFFFF;">
         <items>
            <VBox alignment="TOP_CENTER" spacing="20.0">
               <children>
                  <Label fx:id="welcomeLabel" text="Welcome" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="20.0" />
                     </font>
                  </Label>
                  <VBox spacing="15.0">
                     <children>
                        <HBox spacing="10.0">
                           <children>
                              <Label text="Filter by Department:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="departmentFilterComboBox" promptText="All Departments" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </ComboBox>
                           </children>
                        </HBox>
                        <HBox spacing="10.0">
                           <children>
                              <Label text="Filter by Status:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="statusFilterComboBox" promptText="All Statuses" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </ComboBox>
                           </children>
                        </HBox>
                        <HBox spacing="10.0">
                           <children>
                              <Button fx:id="applyFilterButton" onAction="#handleApplyFilter" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;">
                                 <font>
                                    <Font name="Inter Bold" size="14.0" />
                                 </font>
                                 <text>Apply Filters</text>
                              </Button>
                              <Button fx:id="clearFilterButton" onAction="#handleClearFilter" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;">
                                 <font>
                                    <Font name="Inter Bold" size="14.0" />
                                 </font>
                                 <text>Clear Filters</text>
                              </Button>
                              <Button fx:id="refreshButton" onAction="#handleRefresh" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;">
                                 <font>
                                    <Font name="Inter Bold" size="14.0" />
                                 </font>
                                 <text>Refresh</text>
                              </Button>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  <TableView fx:id="complaintsTable" prefHeight="400.0">
                     <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="complaintId" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="titleColumn" text="Title" prefWidth="150.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="title" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="lodgedByColumn" text="Lodged By" prefWidth="120.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="lodgedBy" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="assignedToDept" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="status" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="lodgedAtColumn" text="Lodged At" prefWidth="120.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="lodgedAt" />
                           </cellValueFactory>
                        </TableColumn>
                     </columns>
                  </TableView>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
            <VBox fx:id="complaintDetailsPanel" alignment="TOP_CENTER" spacing="20.0" visible="false">
               <children>
                  <Label text="Complaint Details" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="18.0" />
                     </font>
                  </Label>
                  <VBox spacing="10.0" style="-fx-border-color: #000080; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-color: #FFFFFF;" maxWidth="350.0">
                     <children>
                        <Label text="Title:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="detailTitleLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Description:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="detailDescriptionLabel" textFill="#000080" wrapText="true">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Lodged By:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="detailLodgedByLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Department:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="detailDepartmentLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Status:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="detailStatusLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Lodged At:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="detailLodgedAtLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Update Status:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <ComboBox fx:id="statusUpdateComboBox" promptText="Select new status" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </ComboBox>
                        <Label text="Remarks:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <TextArea fx:id="remarksArea" promptText="Enter remarks" prefHeight="100.0" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </TextArea>
                        <Button fx:id="updateStatusButton" onAction="#handleUpdateStatus" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;">
                           <font>
                              <Font name="Inter Bold" size="14.0" />
                           </font>
                           <text>Update Status</text>
                        </Button>
                        <Label fx:id="updateStatusLabel" textFill="#dc3545" visible="false">
                           <font>
                              <Font name="Inter" size="12.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" style="-fx-background-color: #000080;">
         <children>
            <Button fx:id="logoutButton" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: WHITE; -fx-border-width: 0;">
               <font>
                  <Font name="Inter Bold" size="12.0" />
               </font>
               <text>Logout</text>
            </Button>
            <Label text="© 2025 Government of India - Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter" size="12.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>