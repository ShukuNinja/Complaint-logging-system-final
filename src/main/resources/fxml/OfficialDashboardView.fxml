<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.OfficialDashboardController">
   <top>
      <VBox styleClass="header">
         <children>
            <Label styleClass="header-title" text="Official Dashboard - Complaint Management System" />
            <Label styleClass="header-subtitle" text="अधिकारी डैशबोर्ड - शिकायत प्रबंधन प्रणाली" />
         </children>
      </VBox>
   </top>
   <center>
      <BorderPane styleClass="content-area">
         <top>
            <VBox styleClass="filter-bar">
               <children>
                  <Label fx:id="welcomeLabel" styleClass="welcome-label" text="Welcome" />
                  <HBox spacing="14.0" alignment="BOTTOM_LEFT">
                     <children>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="DEPARTMENT" />
                              <ComboBox fx:id="departmentFilterComboBox" promptText="All Departments" prefWidth="200.0" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="STATUS" />
                              <ComboBox fx:id="statusFilterComboBox" promptText="All Statuses" prefWidth="150.0" />
                           </children>
                        </VBox>
                        <Button fx:id="applyFilterButton" onAction="#handleApplyFilter" text="Apply Filter" />
                        <Button fx:id="clearFilterButton" styleClass="btn-secondary" onAction="#handleClearFilter" text="Clear" />
                        <Button fx:id="refreshButton" styleClass="btn-secondary" onAction="#handleRefresh" text="Refresh" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </top>
         <center>
            <SplitPane dividerPositions="0.6">
               <items>
                  <VBox spacing="12.0">
                     <children>
                        <Label styleClass="section-title" text="All Complaints" />
                        <TableView fx:id="complaintsTable" prefHeight="500.0" VBox.vgrow="ALWAYS">
                           <columns>
                              <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0" />
                              <TableColumn fx:id="titleColumn" text="Title" prefWidth="200.0" />
                              <TableColumn fx:id="lodgedByColumn" text="Lodged By" prefWidth="120.0" />
                              <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120.0" />
                              <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0" />
                              <TableColumn fx:id="lodgedAtColumn" text="Lodged At" prefWidth="130.0" />
                           </columns>
                        </TableView>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="10.0" top="20.0" />
                     </padding>
                  </VBox>
                  <ScrollPane fitToWidth="true" styleClass="content-area">
                     <content>
                        <VBox fx:id="complaintDetailsPanel" spacing="14.0" styleClass="card">
                           <children>
                              <Label styleClass="section-title" text="Complaint Details" />
                              <Separator />
                              <VBox spacing="4.0">
                                 <children>
                                    <Label styleClass="detail-key" text="Title" />
                                    <Label fx:id="detailTitleLabel" styleClass="detail-value" text="" wrapText="true" />
                                 </children>
                              </VBox>
                              <VBox spacing="4.0">
                                 <children>
                                    <Label styleClass="detail-key" text="Description" />
                                    <Label fx:id="detailDescriptionLabel" styleClass="detail-value" text="" wrapText="true" />
                                 </children>
                              </VBox>
                              <HBox spacing="30.0">
                                 <children>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="detail-key" text="Lodged By" />
                                          <Label fx:id="detailLodgedByLabel" styleClass="detail-value" text="" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="detail-key" text="Department" />
                                          <Label fx:id="detailDepartmentLabel" styleClass="detail-value" text="" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <HBox spacing="30.0">
                                 <children>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="detail-key" text="Status" />
                                          <Label fx:id="detailStatusLabel" styleClass="detail-value" text="" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="detail-key" text="Lodged At" />
                                          <Label fx:id="detailLodgedAtLabel" styleClass="detail-value" text="" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <Separator />
                              <Label styleClass="section-title" text="Update Status" />
                              <VBox spacing="6.0">
                                 <children>
                                    <Label styleClass="field-label" text="NEW STATUS" />
                                    <ComboBox fx:id="statusUpdateComboBox" maxWidth="Infinity" promptText="Select new status" />
                                 </children>
                              </VBox>
                              <VBox spacing="6.0">
                                 <children>
                                    <Label styleClass="field-label" text="REMARKS" />
                                    <TextArea fx:id="remarksArea" promptText="Enter remarks (optional)" prefHeight="80.0" wrapText="true" />
                                 </children>
                              </VBox>
                              <Button fx:id="updateStatusButton" maxWidth="Infinity" onAction="#handleUpdateStatus" text="Update Status" />
                              <Label fx:id="updateStatusLabel" styleClass="error-label" visible="false" wrapText="true" />
                           </children>
                        </VBox>
                     </content>
                  </ScrollPane>
               </items>
            </SplitPane>
         </center>
      </BorderPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" styleClass="footer">
         <children>
            <Button fx:id="profileButton" styleClass="footer-link" onAction="#handleProfile" text="My Profile" />
            <Button fx:id="logoutButton" styleClass="footer-link" onAction="#handleLogout" text="Logout" />
            <Label styleClass="footer-text" text="© 2025 Government of India - Complaint Management System" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
