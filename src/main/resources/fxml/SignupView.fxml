<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.SignupController">
   <top>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FF9933;">
         <children>
            <Label text="Citizen Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter Bold" size="28.0" />
               </font>
            </Label>
            <Label text="सरकारी शिकायत प्रबंधन प्रणाली" textFill="WHITE">
               <font>
                  <Font name="Inter" size="16.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #FFFFFF;">
         <children>
            <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #000080; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" maxWidth="450.0">
               <children>
                  <Label text="Create Account" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="24.0" />
                     </font>
                  </Label>
                  <VBox spacing="15.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Full Name:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="fullNameField" promptText="Enter your full name" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Username:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="usernameField" promptText="Choose a username" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Email:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="emailField" promptText="Enter your email address" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Password:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <PasswordField fx:id="passwordField" promptText="Create a password" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </PasswordField>
                              <Label text="Password must be at least 8 characters with uppercase, lowercase, digit, and special character" textFill="#6c757d">
                                 <font>
                                    <Font name="Inter" size="10.0" />
                                 </font>
                              </Label>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Confirm Password:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </PasswordField>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Account Type:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="roleComboBox" promptText="Select account type" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </ComboBox>
                           </children>
                        </VBox>
                        <Button fx:id="signupButton" maxWidth="Infinity" onAction="#handleSignup" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;">
                           <font>
                              <Font name="Inter Bold" size="16.0" />
                           </font>
                           <text>Create Account</text>
                        </Button>
                        <HBox alignment="CENTER" spacing="10.0">
                           <children>
                              <Label text="Already have an account?" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="12.0" />
                                 </font>
                              </Label>
                              <Button fx:id="loginLinkButton" onAction="#handleLoginLink" style="-fx-background-color: transparent; -fx-text-fill: #000080; -fx-underline: true; -fx-border-width: 0;">
                                 <font>
                                    <Font name="Inter Bold" size="12.0" />
                                 </font>
                                 <text>Login here</text>