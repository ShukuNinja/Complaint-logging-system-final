<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.SignupController">
   <top>
      <VBox styleClass="header">
         <children>
            <Label styleClass="header-title" text="Citizen Complaint Management System" />
            <Label styleClass="header-subtitle" text="सरकारी शिकायत प्रबंधन प्रणाली" />
         </children>
      </VBox>
   </top>
   <center>
      <ScrollPane fitToWidth="true" styleClass="content-area">
         <content>
            <VBox alignment="CENTER" styleClass="content-area">
               <children>
                  <VBox spacing="20.0" styleClass="card" maxWidth="460.0">
                     <children>
                        <VBox spacing="4.0">
                           <children>
                              <Label styleClass="card-title" text="Create your account" />
                              <Label styleClass="hint-label" text="Register to lodge and track complaints" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="FULL NAME" />
                              <TextField fx:id="fullNameField" promptText="Enter your full name" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="USERNAME" />
                              <TextField fx:id="usernameField" promptText="Choose a username" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="EMAIL" />
                              <TextField fx:id="emailField" promptText="Enter your email address" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="ACCOUNT TYPE" />
                              <ComboBox fx:id="roleComboBox" maxWidth="Infinity" promptText="Select account type" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="PASSWORD" />
                              <PasswordField fx:id="passwordField" promptText="Create a password" />
                              <Label styleClass="hint-label" wrapText="true" text="Password must be at least 8 characters with uppercase, lowercase, digit, and special character" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="CONFIRM PASSWORD" />
                              <PasswordField fx:id="confirmPasswordField" promptText="Confirm your password" />
                           </children>
                        </VBox>
                        <Button fx:id="signupButton" maxWidth="Infinity" onAction="#handleSignup" text="Create Account" />
                        <HBox alignment="CENTER" spacing="6.0">
                           <children>
                              <Label styleClass="hint-label" text="Already have an account?" />
                              <Button fx:id="loginLinkButton" styleClass="link-button" onAction="#handleLoginLink" text="Login here" />
                           </children>
                        </HBox>
                        <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true" />
                        <Label fx:id="successLabel" styleClass="success-label" visible="false" wrapText="true" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="40.0" left="50.0" right="50.0" top="40.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>
   <bottom>
      <HBox alignment="CENTER" styleClass="footer">
         <children>
            <Label styleClass="footer-text" text="© 2025 Government of India - Complaint Management System" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
