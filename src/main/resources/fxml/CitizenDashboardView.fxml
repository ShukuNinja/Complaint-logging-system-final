<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.CitizenDashboardController">
   <top>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FF9933;">
         <children>
            <Label text="Citizen Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter Bold" size="28.0" />
               </font>
            </Label>
            <Label text="सरकारी शिकायत प्रबंधन प्रणाली" textFill="WHITE">
               <font>
                  <Font name="Inter" size="16.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.4" style="-fx-background-color: #FFFFFF;">
         <items>
            <VBox alignment="TOP_CENTER" spacing="20.0">
               <children>
                  <Label fx:id="welcomeLabel" text="Welcome" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="20.0" />
                     </font>
                  </Label>
                  <VBox alignment="CENTER" spacing="15.0" style="-fx-border-color: #000080; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-color: #FFFFFF;" maxWidth="350.0">
                     <children>
                        <Label text="Lodge a Complaint" textFill="#000080">
                           <font>
                              <Font name="Inter Bold" size="18.0" />
                           </font>
                        </Label>
                        <VBox spacing="10.0">
                           <children>
                              <Label text="Title:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="titleField" promptText="Enter complaint title" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox spacing="10.0">
                           <children>
                              <Label text="Department:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <ComboBox fx:id="departmentComboBox" maxWidth="Infinity" promptText="Select department" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5;">
                              </ComboBox>
                           </children>
                        </VBox>
                        <VBox spacing="10.0">
                           <children>
                              <Label text="Description:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <TextArea fx:id="descriptionArea" promptText="Enter complaint description" prefHeight="100.0" wrapText="true" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </TextArea>
                           </children>
                        </VBox>
                        <Button fx:id="submitButton" maxWidth="Infinity" onAction="#handleSubmitComplaint" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10; -fx-cursor: hand;">
                           <font>
                              <Font name="Inter Bold" size="16.0" />
                           </font>
                           <text>Submit Complaint</text>
                        </Button>
                        <Label fx:id="statusLabel" textFill="#dc3545" visible="false" wrapText="true">
                           <font>
                              <Font name="Inter" size="12.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
            <VBox alignment="TOP_CENTER" spacing="20.0">
               <children>
                  <Label text="Your Complaints" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="18.0" />
                     </font>
                  </Label>
                  <TableView fx:id="complaintsTable" prefHeight="400.0">
                     <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0" />
                        <TableColumn fx:id="titleColumn" text="Title" prefWidth="150.0" />
                        <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120.0" />
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0" />
                        <TableColumn fx:id="lodgedAtColumn" text="Lodged At" prefWidth="120.0" />
                     </columns>
                  </TableView>
                  <HBox spacing="10.0" alignment="CENTER">
                     <children>
                        <Button fx:id="viewDetailsButton" onAction="#handleViewDetails" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10; -fx-cursor: hand;">
                           <font>
                              <Font name="Inter Bold" size="14.0" />
                           </font>
                           <text>View Details</text>
                        </Button>
                        <Button fx:id="refreshButton" onAction="#handleRefresh" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10; -fx-cursor: hand;">
                           <font>
                              <Font name="Inter Bold" size="14.0" />
                           </font>
                           <text>Refresh</text>
                        </Button>
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #000080;">
         <children>
            <Button fx:id="logoutButton" onAction="#handleLogout" style="-fx-background-color: transparent; -fx-text-fill: WHITE; -fx-border-width: 0; -fx-cursor: hand;">
               <font>
                  <Font name="Inter Bold" size="12.0" />
               </font>
               <text>Logout</text>
            </Button>
            <Label text="© 2025 Government of India - Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter" size="12.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>