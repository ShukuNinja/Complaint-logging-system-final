<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.CitizenDashboardController">
   <top>
      <VBox styleClass="header">
         <children>
            <Label styleClass="header-title" text="Citizen Complaint Management System" />
            <Label styleClass="header-subtitle" text="सरकारी शिकायत प्रबंधन प्रणाली" />
         </children>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.42" styleClass="content-area">
         <items>
            <VBox alignment="TOP_LEFT" spacing="16.0">
               <children>
                  <Label fx:id="welcomeLabel" styleClass="welcome-label" text="Welcome" />
                  <VBox spacing="16.0" styleClass="card">
                     <children>
                        <Label styleClass="section-title" text="Lodge a Complaint" />
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="TITLE" />
                              <TextField fx:id="titleField" promptText="Enter complaint title" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="DEPARTMENT" />
                              <ComboBox fx:id="departmentComboBox" maxWidth="Infinity" promptText="Select department" />
                           </children>
                        </VBox>
                        <VBox spacing="6.0">
                           <children>
                              <Label styleClass="field-label" text="DESCRIPTION" />
                              <TextArea fx:id="descriptionArea" promptText="Enter complaint description" prefHeight="110.0" wrapText="true" />
                           </children>
                        </VBox>
                        <Button fx:id="submitButton" maxWidth="Infinity" onAction="#handleSubmitComplaint" text="Submit Complaint" />
                        <Label fx:id="statusLabel" styleClass="error-label" visible="false" wrapText="true" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="24.0" left="24.0" right="12.0" top="24.0" />
               </padding>
            </VBox>
            <VBox alignment="TOP_LEFT" spacing="16.0">
               <children>
                  <Label styleClass="section-title" text="Your Complaints" />
                  <TableView fx:id="complaintsTable" prefHeight="400.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50.0" />
                        <TableColumn fx:id="titleColumn" text="Title" prefWidth="150.0" />
                        <TableColumn fx:id="departmentColumn" text="Department" prefWidth="120.0" />
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="100.0" />
                        <TableColumn fx:id="lodgedAtColumn" text="Lodged At" prefWidth="120.0" />
                     </columns>
                  </TableView>
                  <HBox spacing="10.0" alignment="CENTER_RIGHT">
                     <children>
                        <Button fx:id="refreshButton" styleClass="btn-secondary" onAction="#handleRefresh" text="Refresh" />
                        <Button fx:id="viewDetailsButton" onAction="#handleViewDetails" text="View Details" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="24.0" left="12.0" right="24.0" top="24.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
   <bottom>
      <HBox alignment="CENTER_LEFT" styleClass="footer">
         <children>
            <Button fx:id="profileButton" styleClass="footer-link" onAction="#handleProfile" text="My Profile" />
            <Button fx:id="logoutButton" styleClass="footer-link" onAction="#handleLogout" text="Logout" />
            <Label styleClass="footer-text" text="© 2025 Government of India - Complaint Management System" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
