<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.LoginController">
   <top>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FF9933;">
         <children>
            <Label text="Citizen Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter Bold" size="28.0" />
               </font>
            </Label>
            <Label text="सरकारी शिकायत प्रबंधन प्रणाली" textFill="WHITE">
               <font>
                  <Font name="Inter" size="16.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #FFFFFF;">
         <children>
            <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FFFFFF; -fx-border-color: #000080; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10;" maxWidth="450.0">
               <children>
                  <Label text="Login" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="24.0" />
                     </font>
                  </Label>
                  <VBox spacing="15.0">
                     <children>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Username:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <TextField fx:id="usernameField" promptText="Enter your username" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </TextField>
                           </children>
                        </VBox>
                        <VBox spacing="5.0">
                           <children>
                              <Label text="Password:" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </Label>
                              <PasswordField fx:id="passwordField" promptText="Enter your password" style="-fx-border-color: #000080; -fx-border-width: 1; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 8;">
                                 <font>
                                    <Font name="Inter" size="14.0" />
                                 </font>
                              </PasswordField>
                           </children>
                        </VBox>
                        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#handleLogin" 
        style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10; -fx-cursor: hand;">
   <font>
      <Font name="Inter Bold" size="16.0" />
   </font>
   <text>Login</text>
</Button>
                        <HBox alignment="CENTER" spacing="10.0">
                           <children>
                              <Label text="Don't have an account?" textFill="#000080">
                                 <font>
                                    <Font name="Inter" size="12.0" />
                                 </font>
                              </Label>
                              <Button fx:id="signupLinkButton" onAction="#handleSignupLink" 
        style="-fx-background-color: transparent; -fx-text-fill: #000080; -fx-underline: true; -fx-border-width: 0; -fx-cursor: hand;">
   <font>
      <Font name="Inter Bold" size="12.0" />
   </font>
   <text>Sign Up here</text>
</Button>
                           </children>
                        </HBox>
                        <Label fx:id="errorLabel" textFill="#dc3545" visible="false">
                           <font>
                              <Font name="Inter" size="12.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>
            </VBox>
         </children>
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" style="-fx-background-color: #000080;">
         <children>
            <Label text="© 2025 Government of India - Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter" size="12.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>