<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.ComplaintDetailsController">
   <top>
      <VBox styleClass="header">
         <children>
            <Label styleClass="header-title" text="Citizen Complaint Management System" />
            <Label styleClass="header-subtitle" text="सरकारी शिकायत प्रबंधन प्रणाली" />
         </children>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.42" styleClass="content-area">
         <items>
            <ScrollPane fitToWidth="true" styleClass="content-area">
               <content>
                  <VBox alignment="TOP_LEFT" spacing="16.0">
                     <children>
                        <Label styleClass="page-title" text="Complaint Details" />
                        <VBox spacing="14.0" styleClass="card">
                           <children>
                              <HBox spacing="8.0" alignment="CENTER_LEFT">
                                 <children>
                                    <Label styleClass="detail-key" text="Complaint ID:" />
                                    <Label fx:id="complaintIdLabel" styleClass="detail-value" />
                                 </children>
                              </HBox>
                              <Separator />
                              <VBox spacing="4.0">
                                 <children>
                                    <Label styleClass="detail-key" text="Title" />
                                    <Label fx:id="titleLabel" styleClass="detail-value" wrapText="true" />
                                 </children>
                              </VBox>
                              <Separator />
                              <VBox spacing="4.0">
                                 <children>
                                    <Label styleClass="detail-key" text="Description" />
                                    <Label fx:id="descriptionLabel" styleClass="detail-value" wrapText="true" />
                                 </children>
                              </VBox>
                              <Separator />
                              <HBox spacing="30.0">
                                 <children>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="detail-key" text="Lodged By" />
                                          <Label fx:id="lodgedByLabel" styleClass="detail-value" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="detail-key" text="Department" />
                                          <Label fx:id="departmentLabel" styleClass="detail-value" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <Separator />
                              <HBox spacing="30.0">
                                 <children>
                                    <VBox spacing="4.0">
                                       <children>
                                          <Label styleClass="detail-key" text="Status" />
                                          <Label fx:id="statusLabel" styleClass="detail-value" />
                                       </children>
                                    </VBox>
                                    <VBox spacing="4.0" HBox.hgrow="ALWAYS">
                                       <children>
                                          <Label styleClass="detail-key" text="Lodged At" />
                                          <Label fx:id="lodgedAtLabel" styleClass="detail-value" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <VBox spacing="4.0">
                                 <children>
                                    <Label styleClass="detail-key" text="Last Updated" />
                                    <Label fx:id="updatedAtLabel" styleClass="detail-value" />
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </children>
                     <padding>
                        <Insets bottom="24.0" left="24.0" right="12.0" top="24.0" />
                     </padding>
                  </VBox>
               </content>
            </ScrollPane>
            <VBox alignment="TOP_LEFT" spacing="16.0">
               <children>
                  <Label styleClass="section-title" text="Status History" />
                  <TableView fx:id="historyTable" prefHeight="400.0" VBox.vgrow="ALWAYS">
                     <columns>
                        <TableColumn fx:id="changedAtColumn" text="Changed At" prefWidth="130.0" />
                        <TableColumn fx:id="changedByColumn" text="Changed By" prefWidth="120.0" />
                        <TableColumn fx:id="previousStatusColumn" text="Previous Status" prefWidth="110.0" />
                        <TableColumn fx:id="newStatusColumn" text="New Status" prefWidth="110.0" />
                        <TableColumn fx:id="remarksColumn" text="Remarks" prefWidth="180.0" />
                     </columns>
                  </TableView>
                  <Label fx:id="noHistoryLabel" styleClass="hint-label" text="No history available for this complaint" visible="false" />
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Button fx:id="backButton" onAction="#handleBack" text="← Back to Dashboard" />
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets bottom="24.0" left="12.0" right="24.0" top="24.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
   <bottom>
      <HBox alignment="CENTER" styleClass="footer">
         <children>
            <Label styleClass="footer-text" text="© 2025 Government of India - Complaint Management System" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
