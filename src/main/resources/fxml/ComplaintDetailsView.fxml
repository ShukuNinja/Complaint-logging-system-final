<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.ComplaintDetailsController">
   <top>
      <VBox alignment="CENTER" spacing="20.0" style="-fx-background-color: #FF9933;">
         <children>
            <Label text="Citizen Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter Bold" size="28.0" />
               </font>
            </Label>
            <Label text="सरकारी शिकायत प्रबंधन प्रणाली" textFill="WHITE">
               <font>
                  <Font name="Inter" size="16.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </top>
   <center>
      <SplitPane dividerPositions="0.4" style="-fx-background-color: #FFFFFF;">
         <items>
            <VBox alignment="TOP_CENTER" spacing="20.0">
               <children>
                  <Label text="Complaint Details" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="18.0" />
                     </font>
                  </Label>
                  <VBox spacing="10.0" style="-fx-border-color: #000080; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-radius: 10; -fx-background-color: #FFFFFF;" maxWidth="350.0">
                     <children>
                        <Label text="Complaint ID:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="complaintIdLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Title:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="titleLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Description:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="descriptionLabel" textFill="#000080" wrapText="true">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Lodged By:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="lodgedByLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Department:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="departmentLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Status:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="statusLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Lodged At:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="lodgedAtLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label text="Updated At:" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                        <Label fx:id="updatedAtLabel" textFill="#000080">
                           <font>
                              <Font name="Inter" size="14.0" />
                           </font>
                        </Label>
                     </children>
                     <padding>
                        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                     </padding>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
            <VBox alignment="TOP_CENTER" spacing="20.0">
               <children>
                  <Label text="Status History" textFill="#000080">
                     <font>
                        <Font name="Inter Bold" size="18.0" />
                     </font>
                  </Label>
                  <TableView fx:id="historyTable" prefHeight="400.0">
                     <columns>
                        <TableColumn fx:id="changedAtColumn" text="Changed At" prefWidth="120.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="changedAt" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="changedByColumn" text="Changed By" prefWidth="120.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="changedBy" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="previousStatusColumn" text="Previous Status" prefWidth="100.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="previousStatus" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="newStatusColumn" text="New Status" prefWidth="100.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="newStatus" />
                           </cellValueFactory>
                        </TableColumn>
                        <TableColumn fx:id="remarksColumn" text="Remarks" prefWidth="150.0">
                           <cellValueFactory>
                              <PropertyValueFactory property="remarks" />
                           </cellValueFactory>
                        </TableColumn>
                     </columns>
                  </TableView>
                  <Label fx:id="noHistoryLabel" text="No history available" textFill="#dc3545" visible="false">
                     <font>
                        <Font name="Inter" size="14.0" />
                     </font>
                  </Label>
                  <Button fx:id="backButton" onAction="#handleBack" style="-fx-background-color: #138808; -fx-text-fill: WHITE; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 10;">
                     <font>
                        <Font name="Inter Bold" size="14.0" />
                     </font>
                     <text>Back</text>
                  </Button>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
               </padding>
            </VBox>
         </items>
      </SplitPane>
   </center>
   <bottom>
      <HBox alignment="CENTER" style="-fx-background-color: #000080;">
         <children>
            <Label text="© 2025 Government of India - Complaint Management System" textFill="WHITE">
               <font>
                  <Font name="Inter" size="12.0" />
               </font>
            </Label>
         </children>
         <padding>
            <Insets bottom="10.0" left="20.0" right="20.0" top="10.0" />
         </padding>
      </HBox>
   </bottom>
</BorderPane>