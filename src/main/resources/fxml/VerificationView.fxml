<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.complaint.system.controller.VerificationController">
   <top>
      <VBox styleClass="header">
         <children>
            <Label styleClass="header-title" text="Citizen Complaint Management System" />
            <Label styleClass="header-subtitle" text="सरकारी शिकायत प्रबंधन प्रणाली" />
         </children>
      </VBox>
   </top>
   <center>
      <VBox alignment="CENTER" styleClass="content-area">
         <children>
            <VBox spacing="20.0" styleClass="card" maxWidth="440.0">
               <children>
                  <VBox spacing="4.0">
                     <children>
                        <Label styleClass="card-title" text="Verify your email" />
                        <Label fx:id="infoLabel" styleClass="hint-label" wrapText="true" text="Enter the 6-digit code we sent to your email." />
                     </children>
                  </VBox>
                  <VBox spacing="6.0">
                     <children>
                        <Label styleClass="field-label" text="VERIFICATION CODE" />
                        <TextField fx:id="codeField" promptText="Enter 6-digit code" />
                     </children>
                  </VBox>
                  <Button fx:id="verifyButton" maxWidth="Infinity" onAction="#handleVerify" text="Verify &amp; Create Account" />
                  <HBox alignment="CENTER" spacing="6.0">
                     <children>
                        <Label styleClass="hint-label" text="Didn't get the code?" />
                        <Button fx:id="resendButton" styleClass="link-button" onAction="#handleResend" text="Resend code" />
                     </children>
                  </HBox>
                  <Label fx:id="errorLabel" styleClass="error-label" visible="false" wrapText="true" />
                  <Label fx:id="successLabel" styleClass="success-label" visible="false" wrapText="true" />
                  <HBox alignment="CENTER">
                     <children>
                        <Button fx:id="backButton" styleClass="link-button" onAction="#handleBackToLogin" text="← Back to Login" />
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
         </padding>
      </VBox>
   </center>
   <bottom>
      <HBox alignment="CENTER" styleClass="footer">
         <children>
            <Label styleClass="footer-text" text="© 2025 Government of India - Complaint Management System" />
         </children>
      </HBox>
   </bottom>
</BorderPane>
