<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>

        <!-- ✅ Correct Oracle Connection for HikariCP -->
        <property name="hibernate.hikari.jdbcUrl">${env.DB_URL:jdbc:oracle:thin:@localhost:1521/XEPDB1}</property>
        <property name="hibernate.hikari.username">${env.DB_USERNAME:complaint_system}</property>
        <property name="hibernate.hikari.password">${env.DB_PASSWORD:password123}</property>
        <property name="hibernate.hikari.driverClassName">oracle.jdbc.OracleDriver</property>

        <property name="hibernate.connection.provider_class">org.hibernate.hikaricp.internal.HikariCPConnectionProvider</property>

        <!-- Pool settings -->
        <property name="hibernate.hikari.minimumIdle">2</property>
        <property name="hibernate.hikari.maximumPoolSize">10</property>
        <property name="hibernate.hikari.idleTimeout">300000</property>
        <property name="hibernate.hikari.maxLifetime">1800000</property>
        <property name="hibernate.hikari.poolName">ComplaintSystemPool</property>

        <!-- Hibernate options -->
        <property name="hibernate.dialect">org.hibernate.dialect.Oracle12cDialect</property>
        <property name="hibernate.hbm2ddl.auto">update</property>
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- Entities -->
        <mapping class="com.complaint.system.entity.User"/>
        <mapping class="com.complaint.system.entity.Department"/>
        <mapping class="com.complaint.system.entity.Complaint"/>
        <mapping class="com.complaint.system.entity.ComplaintHistory"/>

    </session-factory>
</hibernate-configuration>
